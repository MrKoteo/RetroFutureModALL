{
  "multipart": [
    { "when": { "north": "true" }, "apply": { "model": "retrofuturemc:glow_lichen" } },
    { "when": { "east": "true" }, "apply": { "model": "retrofuturemc:glow_lichen", "uvlock": true, "y": 90 } },
    { "when": { "south": "true" }, "apply": { "model": "retrofuturemc:glow_lichen", "uvlock": true, "y": 180 } },
    { "when": { "west": "true" }, "apply": { "model": "retrofuturemc:glow_lichen", "uvlock": true, "y": 270 } },
    { "when": { "up": "true" }, "apply": { "model": "retrofuturemc:glow_lichen", "uvlock": true, "x": 270 } },
    { "when": { "down": "true" }, "apply": { "model": "retrofuturemc:glow_lichen", "uvlock": true, "x": 90 } }
  ]
}